{
  "name": "whitespace-ignore-search",
  "displayName": "Whitespace Ignore Search",
  "description": "Automatically generate whitespace-tolerant patterns while keeping your specific regex logic intact.",
  "publisher": "takumi-onisi",
  "version": "0.1.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/takumi-onisi/whitespace-ignore-search.git"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "license": "MIT",
  "icon": "media/whitespace-ignore-search-icon.png", 
  "homepage": "https://github.com/takumi-onisi/whitespace-ignore-search#readme",
  "bugs": {
    "url": "https://github.com/takumi-onisi/whitespace-ignore-search/issues"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "search",
    "regex",
    "whitespace",
    "ignore whitespace",
    "productivity"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media"
  ],
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "extension.showIgnoreWhitespacePanel",
        "title": "%command.title%"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:vscode": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "happy-dom": "^20.5.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@vscode/l10n": "^0.0.18"
  }
}
